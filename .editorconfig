root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{rs,py,c,h}]
indent_style = space
indent_size = 4

[*.{yml,yaml,toml,json,tf,lean}]
indent_style = space
indent_size = 2

[*.md]
# Trailing double-space is a hard line break in Markdown.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
